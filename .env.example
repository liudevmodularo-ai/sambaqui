# ============================================================================
# ARQUIVO DE EXEMPLO DE CONFIGURAÇÃO - SAMBAQUI TOWER HOUSE
# ============================================================================
# Copie este arquivo para .env e preencha com seus valores.
# Os scripts install.sh e reinstall.sh usarão estas variáveis.

# --- Configurações da Aplicação Flask ---
FLASK_ENV=production
FLASK_APP=app.py
# Gere uma nova chave com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="change-this-in-production-to-a-real-secret-key"

# --- Configurações de Deploy (usado por install.sh e reinstall.sh) ---
INSTALL_DIR="/var/www/sambaqui"
APP_USER="www-data"
APP_PORT="5000"
GIT_REPO="https://github.com/liudevmodularo-ai/sambaqui.git"

# --- Configurações de Domínio e SSL ---
# Use o domínio raiz, sem http/https ou / no final. Ex: ilhasincorporadora.com.br
SERVER_HOST="ilhasincorporadora.com.br"
SSL_EMAIL="dev@synapt.com.br"
# Usar HTTPS? (s/n)
USE_HTTPS="s"